  "components": {
    "schemas": {
      "AddCourseSkillTagDto": {
        "required": [
          "codeModule",
          "codePresentation",
          "level",
          "skillName"
        ],
        "type": "object",
        "properties": {
          "codeModule": {
            "maxLength": 45,
            "minLength": 1,
            "type": "string"
          },
          "codePresentation": {
            "maxLength": 45,
            "minLength": 1,
            "type": "string"
          },
          "skillName": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string"
          },
          "level": {
            "minLength": 1,
            "pattern": "^(Beginner|Intermediate|Advanced)$",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "Assessment": {
        "type": "object",
        "properties": {
          "idAssessment": {
            "type": "integer",
            "format": "int32"
          },
          "codeModule": {
            "type": "string",
            "nullable": true
          },
          "codePresentation": {
            "type": "string",
            "nullable": true
          },
          "assessmentType": {
            "type": "string",
            "nullable": true
          },
          "date": {
            "type": "string",
            "nullable": true
          },
          "course": {
            "$ref": "#/components/schemas/Course"
          }
        },
        "additionalProperties": false
      },
      "Course": {
        "type": "object",
        "properties": {
          "codeModule": {
            "type": "string",
            "nullable": true
          },
          "codePresentation": {
            "type": "string",
            "nullable": true
          },
          "assessments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Assessment"
            },
            "nullable": true
          },
          "studentInfos": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/StudentInfo"
            },
            "nullable": true
          },
          "vles": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Vle"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "RegisterDto": {
        "type": "object",
        "properties": {
          "studentId": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "nullable": true
          },
          "firstName": {
            "type": "string",
            "nullable": true
          },
          "lastName": {
            "type": "string",
            "nullable": true
          },
          "role": {
            "$ref": "#/components/schemas/UserRole"
          }
        },
        "additionalProperties": false
      },
      "StudentInfo": {
        "type": "object",
        "properties": {
          "codeModule": {
            "type": "string",
            "nullable": true
          },
          "codePresentation": {
            "type": "string",
            "nullable": true
          },
          "idStudent": {
            "type": "integer",
            "format": "int32"
          },
          "gender": {
            "type": "string",
            "nullable": true
          },
          "imdBand": {
            "type": "string",
            "nullable": true
          },
          "highestEducation": {
            "type": "string",
            "nullable": true
          },
          "ageBand": {
            "type": "string",
            "nullable": true
          },
          "numOfPrevAttempts": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "studiedCredits": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "region": {
            "type": "string",
            "nullable": true
          },
          "disability": {
            "type": "string",
            "nullable": true
          },
          "finalResult": {
            "type": "string",
            "nullable": true
          },
          "course": {
            "$ref": "#/components/schemas/Course"
          }
        },
        "additionalProperties": false
      },
      "UpdateAcademicProfileDto": {
        "type": "object",
        "properties": {
          "gender": {
            "type": "string",
            "nullable": true
          },
          "highestEducation": {
            "type": "string",
            "nullable": true
          },
          "ageBand": {
            "type": "string",
            "nullable": true
          },
          "region": {
            "type": "string",
            "nullable": true
          },
          "imdBand": {
            "type": "string",
            "nullable": true
          },
          "studiedCredits": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "numOfPrevAttempts": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "disability": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "UpdateSkillDto": {
        "required": [
          "skillName",
          "targetLevel"
        ],
        "type": "object",
        "properties": {
          "skillName": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string"
          },
          "targetLevel": {
            "minLength": 1,
            "pattern": "^(Beginner|Intermediate|Advanced)$",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "UserRole": {
        "enum": [
          0,
          1
        ],
        "type": "integer",
        "format": "int32"
      },
      "Vle": {
        "type": "object",
        "properties": {
          "idSite": {
            "type": "integer",
            "format": "int32"
          },
          "codeModule": {
            "type": "string",
            "nullable": true
          },
          "codePresentation": {
            "type": "string",
            "nullable": true
          },
          "activityType": {
            "type": "string",
            "nullable": true
          },
          "weekFrom": {
            "type": "string",
            "nullable": true
          },
          "weekTo": {
            "type": "string",
            "nullable": true
          },
          "course": {
            "$ref": "#/components/schemas/Course"
          }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "description": "Enter JWT Token in the format: Bearer {your token}",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
